<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="รายงานวิเคราะห์สาย" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="cce411a4-41e9-4188-a8b2-b6ac0c0ba3e8">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="payroll"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="report" class="java.lang.String"/>
	<parameter name="startDate" class="java.lang.String">
		<defaultValueExpression><![CDATA["2025-12-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="endDate" class="java.lang.String">
		<defaultValueExpression><![CDATA["2025-12-10"]]></defaultValueExpression>
	</parameter>
	<parameter name="comCode" class="java.lang.String">
		<defaultValueExpression><![CDATA["01"]]></defaultValueExpression>
	</parameter>
	<query language="sql"><![CDATA[SELECT
    c.comName As company_name,
    v.comCode,
    STR_TO_DATE(v.dateAt, '%Y-%m-%d') AS work_date,
    DATE_FORMAT(STR_TO_DATE(v.dateAt, '%Y-%m-%d'), '%d/%m') AS day_label,

    COUNT(DISTINCT e.empCode) AS total_employees,
    ROUND(
        100 * SUM(v.status = 'FullDay') / NULLIF(COUNT(*), 0),
        1
    ) AS attendance_rate,
    ROUND(
        100 * SUM(v.status = 'HalfDay') / NULLIF(COUNT(*), 0),
        1
    ) AS half_day_rate,
    ROUND(
        100 * SUM(v.status = 'Absent') / NULLIF(COUNT(*), 0),
        1
    ) AS absent_rate,
ROUND(
    100 * SUM(
        CASE
            WHEN v.status IN ('FullDay','HalfDay')
             AND (
                  COALESCE(v.late_morning_minutes, 0) > 0
                  OR COALESCE(v.late_lunch_minutes, 0) > 0
             )
            THEN 1
            ELSE 0
        END
    ) / NULLIF(
        SUM(
            CASE
                WHEN v.status IN ('FullDay','HalfDay') THEN 1
                ELSE 0
            END
        ),
        0
    ),
    2
) AS late_rate,

ROUND(
    SUM(
        CASE
            WHEN v.status IN ('FullDay','HalfDay') THEN
                COALESCE(v.late_morning_minutes, 0) +
                COALESCE(v.late_lunch_minutes, 0)
            ELSE 0
        END
    ) / NULLIF(
        SUM(
            CASE
                WHEN v.status IN ('FullDay','HalfDay')
                 AND (
                      COALESCE(v.late_morning_minutes, 0) > 0
                      OR COALESCE(v.late_lunch_minutes, 0) > 0
                 )
                THEN 1
                ELSE 0
            END
        ),
        0
    ),
    0
) AS avg_late_minutes
FROM attendance v
JOIN employee e
    ON v.comCode = e.comCode
   AND v.empCode = e.empCode
JOIN company c
   ON c.comCode = e.comCode

WHERE FIND_IN_SET(v.comCode, REPLACE($P{comCode}, ' ', '')) > 0
  AND v.dateAt BETWEEN $P{startDate} AND $P{endDate}

GROUP BY
    v.comCode,
    c.comName,
    v.dateAt

ORDER BY
    v.comCode,
    v.dateAt]]></query>
