<jasperReport name="เช็คเวลาประจำวัน" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="784f38b8-bca0-4d99-bf12-459c9169125b">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="payroll"/>
	<property name="com.jaspersoft.studio.report.description" value=""/>
	<parameter name="startDate" class="java.lang.String">
		<defaultValueExpression><![CDATA["2025-12-02"]]></defaultValueExpression>
	</parameter>
	<parameter name="endDate" class="java.lang.String">
		<defaultValueExpression><![CDATA["2025-12-03"]]></defaultValueExpression>
	</parameter>
	<parameter name="comCode" class="java.lang.String">
		<defaultValueExpression><![CDATA["01"]]></defaultValueExpression>
	</parameter>
	<parameter name="report" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT v.*,
       e.comCode AS ecom,
       c.comCode AS ccom,
       e.name    AS employee_name,
       c.comName AS company_name,
       e.scanCode
FROM attendance v
JOIN employee e
  ON v.comCode = e.comCode
 AND v.empCode = e.empCode
JOIN company c
  ON c.comCode = e.comCode
WHERE  e.comCode = $P{comCode} and  v.dateAt between $P{startDate} and $P{endDate} 
ORDER BY e.comCode,v.dateAt,e.empCode
LIMIT 500]]></query>
