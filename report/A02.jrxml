	<variable name="vgAvgLunchOut" resetType="Group" calculation="Average" resetGroup="empCode" class="java.lang.Double">
		<expression><![CDATA[$F{lunch_out} == null ? null :
(
Double.valueOf($F{lunch_out}.substring(0,2)) * 3600 +
Double.valueOf($F{lunch_out}.substring(3,5)) * 60
)]]></expression>
	</variable>
	<variable name="vgMinLunchOut" resetType="Group" calculation="Lowest" resetGroup="empCode" class="java.lang.Double">
