<jasperReport name="ตรวจสอบรายบุคคล " language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="bba2fe40-67ff-4d64-b259-95f5fb717ef1">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="payroll"/>
	<parameter name="startDate" class="java.lang.String">
		<defaultValueExpression><![CDATA["2025-12-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="endDate" class="java.lang.String">
		<defaultValueExpression><![CDATA["2025-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="comCode" class="java.lang.String">
		<defaultValueExpression><![CDATA["01"]]></defaultValueExpression>
	</parameter>
	<parameter name="empCode" class="java.lang.String"/>
	<parameter name="dateStart" evaluationTime="Late" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.sql.Date(
    new java.text.SimpleDateFormat("yyyy-MM-dd").parse($P{startDate}).getTime()
)]]></defaultValueExpression>
	</parameter>
	<parameter name="dateEnd" evaluationTime="Late" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.sql.Date(
    new java.text.SimpleDateFormat("yyyy-MM-dd").parse($P{endDate}).getTime()
)]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT
    v.*,
    e.comCode   AS comCode,
    c.comName   AS company_name,
    e.scanCode  AS scanCode,
    e.name   AS employee_name
FROM attendance v
JOIN employee e
    ON v.comCode = e.comCode
   AND v.empCode = e.empCode
LEFT JOIN company c
    ON c.comCode = e.comCode
WHERE v.comCode = $P{comCode}                     -- ต้องกรอกเสมอ
  AND ($P{empCode} IS NULL OR v.empCode = $P{empCode})  -- ไม่กรอก = เอาทุกคน, กรอก = เฉพาะคนนั้น
  AND STR_TO_DATE(v.dateAt,'%Y-%m-%d')
      BETWEEN $P{startDate} AND $P{endDate}
ORDER BY  e.comCode, e.empCode,v.dateAt]]></query>
