		<expression><![CDATA[($F{morning} != null && !$F{morning}.trim().equals("")) &&
($F{evening} != null && !$F{evening}.trim().equals("")) &&
($F{lunch_out} == null || $F{lunch_out}.trim().equals("")) &&
($F{lunch_in} == null || $F{lunch_in}.trim().equals("")) ? 1 : 0]]></expression>
	</variable>
