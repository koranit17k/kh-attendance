<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="รายงานวิเคราะห์พนักงาน" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="8d4f381e-dcc0-4411-a9b1-6b732bc634e8" floatColumnFooter="true">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="payroll"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="pYear" class="java.lang.Integer"/>
	<parameter name="pMonth" class="java.lang.Integer"/>
	<query language="sql"><![CDATA[SELECT
	v.*,
	e.scanCode ,
	v.dateAt,
	COUNT(*) AS total_cnt,
	--     count(*),
	--     e.comCode   AS ecom,
	--     c.comCode   AS ccom,
	--     c.comName   AS company_name,
	    e.scanCode  AS scanCode,
	e.name   AS employee_name,
	SUM(v.status = 'FullDay') AS full_day_cnt,
	SUM(v.status = 'HalfDay') AS half_day_cnt,
	SUM(v.status = 'Absent') AS absent_cnt,
	SUM(v.late_morning_minutes + v.late_lunch_minutes ) as total_late,
	    SUM(v.status IN ('FullDay','HalfDay')) AS working_days,
    -- รวมสาย (นาที)
    SUM(
        COALESCE(v.late_morning_minutes,0) +
        COALESCE(v.late_lunch_minutes,0)
    ) AS sum_late_min,
    -- รวมเวลาทำงาน/OT (นาที)
    SUM(COALESCE(v.work_minutes,0)) AS sum_work_min,
    SUM(COALESCE(v.ot_total_minutes,0))   AS sum_ot_min,
    -- รวมเวลาเข้างาน (นาที) เฉลี่ยจากวันทำงานจริงเท่านั้น
    SUM(
        CASE
            WHEN v.status IN ('FullDay','HalfDay')
            THEN COALESCE(v.morning,0)
            ELSE 0
        END
    ) AS sum_checkin_min
	FROM
	attendance v
JOIN employee e
    ON
	v.comCode = e.comCode
	AND v.empCode = e.empCode
	-- LEFT JOIN company c
	--     ON c.comCode = e.comCode
WHERE
	    YEAR(STR_TO_DATE(v.dateAt,'%Y-%m-%d'))  = $P{pYear}
	  AND MONTH(STR_TO_DATE(v.dateAt,'%Y-%m-%d')) = $P{pMonth} 
-- 	ORDER BY v.dateAt, e.scanCode
group by e.scanCode  ]]></query>
